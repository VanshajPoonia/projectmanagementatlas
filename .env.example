# Resend transactional email (https://resend.com)
# Server-side only — never prefix with NEXT_PUBLIC_.
RESEND_API_KEY=

# From address. Must be on a domain verified in your Resend dashboard.
# The resend.dev fallback only delivers to your own Resend account email,
# so set this before sending to real recipients.
EMAIL_FROM="Project Manager <notifications@yourdomain.com>"

# Gemini API key for the built-in AI chat widget (https://aistudio.google.com/apikey).
# Server-side only — never prefix with NEXT_PUBLIC_. Free tier; see lib/ai-chat.ts
# for the model used and the shared daily-quota guard.
GEMINI_API_KEY=
